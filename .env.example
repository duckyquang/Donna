# Donna — example configuration
#
# Donna stores API keys and OAuth tokens SECURELY in your OS keychain via the app's
# Settings screen, NOT in this file. This file only holds non-secret, optional config
# useful for development. Copy it to `.env` to override defaults.
#
# Do NOT put real secrets here. `.env` is gitignored, but keychain storage is the
# supported, secure path for credentials.

# Local model runtime (Ollama). Change only if Ollama runs on a non-default host/port.
OLLAMA_HOST=http://localhost:11434

# Default model provider to preselect in onboarding: ollama | openai | anthropic | google
DONNA_DEFAULT_PROVIDER=ollama

# Default local model suggested during onboarding.
DONNA_DEFAULT_LOCAL_MODEL=qwen2.5

# Logging level for development: error | warn | info | debug
DONNA_LOG_LEVEL=info
