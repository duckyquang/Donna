# Donna Server — Environment Configuration
# Copy to .env and fill in your values, or export these before running.

# ── Messaging (choose WhatsApp or Telegram) ──────────────────────────────────
DONNA_WHATSAPP_TOKEN=      # Meta permanent access token
DONNA_WHATSAPP_PHONE_ID=   # Phone number ID from Meta Business dashboard
DONNA_MY_WHATSAPP=         # YOUR own WhatsApp number (E.164 format, e.g. +84123456789)
DONNA_TELEGRAM_TOKEN=      # Telegram bot token from @BotFather
DONNA_TELEGRAM_CHAT_ID=    # Your Telegram user/chat ID

# ── Google Calendar ──────────────────────────────────────────────────────────
DONNA_GOOGLE_CLIENT_ID=
DONNA_GOOGLE_CLIENT_SECRET=
DONNA_GOOGLE_REFRESH_TOKEN= # Export from Donna desktop: Settings > Export Google Token

# ── AI Provider (optional — enriches briefings) ──────────────────────────────
DONNA_AI_PROVIDER=openai    # openai | anthropic | ollama | none
DONNA_AI_KEY=               # API key (leave blank for ollama)
DONNA_AI_MODEL=gpt-4o-mini  # Model name
DONNA_OLLAMA_URL=           # http://your-machine:11434 (for ollama only)

# ── Location (for weather) ───────────────────────────────────────────────────
DONNA_LAT=10.8231           # Latitude  (Ho Chi Minh City default)
DONNA_LON=106.6297          # Longitude

# ── Schedule ─────────────────────────────────────────────────────────────────
DONNA_NEWS_HOUR=9           # Send tech news at this hour (24h)
DONNA_BRIEFING_HOUR=8       # Send morning briefing at this hour
