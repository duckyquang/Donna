# donna-server — environment configuration
# Copy to .env and fill in your values.

# Bearer token the desktop app (and any other client) must send to talk to this
# server. Required — the server refuses to start without it.
DONNA_TOKEN=change-me

# Port the server listens on.
DONNA_PORT=8377

# Cloudflare Tunnel token (Zero Trust dashboard → Networks → Tunnels → create a
# tunnel → public hostname pointing at http://donna:8377). Optional: only needed
# once you want the server reachable from outside your network — e.g. Phase 3's
# WhatsApp webhook, or connecting the desktop app from elsewhere. Leave blank to
# run the tunnel sidecar without it doing anything.
TUNNEL_TOKEN=
