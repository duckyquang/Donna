{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Donna",
  "version": "0.2.1",
  "identifier": "ai.donna.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Donna",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJENzVBNEM0NTBFM0FDOTQKUldTVXJPTlF4S1IxdmFMV3RJUlNrNkF5ZnBQelpTeXdWdnYvRytCMyt2YzV2L0dMMUFlNG4rT3cK",
      "endpoints": [
        "https://github.com/duckyquang/Donna/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/donna-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
